# SwarmCast Configuration
# At least one LLM API key is required

# OpenAI (recommended for speed)
OPENAI_API_KEY=sk-...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AI...

# Which provider to use: openai | anthropic | gemini
LLM_PROVIDER=openai
REQUIRE_LLM_KEY=true

# Location for weather forecasts (defaults to the primary home base)
LATITUDE=39.9870
LONGITUDE=-90.7601
LOCATION_NAME=Mt. Sterling, IL

# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=3777
TRUST_PROXY=false
JSON_BODY_LIMIT=256kb
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=5000
HEADERS_TIMEOUT_MS=60000
SHUTDOWN_TIMEOUT_MS=15000
EXTERNAL_TIMEOUT_MS=15000
EXTERNAL_RETRIES=1
EXTERNAL_RETRY_BACKOFF_MS=400
STREAM_HEARTBEAT_MS=15000
RATE_LIMIT_WINDOW_MS=60000
EXPENSIVE_ROUTE_LIMIT=6
ADMIN_ROUTE_LIMIT=30
ALLOWED_ORIGIN=
DATA_DIR=./data

# Optional hardening
# Set to require the header x-swarmcast-admin-key on mutating routes.
ADMIN_API_KEY=
